{
  "defaults": {
    "mode": "single-agent",
    "timeoutMs": 900000,
    "maxInputTokens": 24000,
    "maxOutputTokens": 8000,
    "maxTurns": 20,
    "maxRetries": 2,
    "maxToolCalls": 40,
    "maxRetrievalFiles": 12,
    "maxRetrievalTokens": 6000,
    "requiredChecks": ["non-empty", "no-placeholders"]
  },
  "categories": {
    "orchestrate": { "mode": "plan-then-execute", "maxInputTokens": 32000 },
    "plan": { "mode": "plan-only", "requiredChecks": ["non-empty"] },
    "code": { "mode": "single-agent", "requiredChecks": ["non-empty", "no-placeholders"] },
    "analyze": { "mode": "single-agent", "requiredChecks": ["non-empty"] },
    "draft": { "mode": "single-agent", "requiredChecks": ["non-empty", "no-placeholders"] },
    "extract": { "mode": "single-agent", "maxInputTokens": 16000, "requiredChecks": ["non-empty", "structured-output"] },
    "classify": { "mode": "single-agent", "maxInputTokens": 12000, "requiredChecks": ["non-empty"] },
    "summarize": { "mode": "single-agent", "maxInputTokens": 16000, "requiredChecks": ["non-empty"] },
    "code-review": { "mode": "review-only", "requiredChecks": ["non-empty"] },
    "lateral": { "mode": "single-agent", "requiredChecks": ["non-empty"] },
    "math": { "mode": "single-agent", "maxOutputTokens": 16000, "requiredChecks": ["non-empty"] },
    "doc-qa": { "mode": "single-agent", "maxInputTokens": 24000, "requiredChecks": ["non-empty", "citations"] },
    "reasoning": { "mode": "single-agent", "maxOutputTokens": 16000, "requiredChecks": ["non-empty"] },
    "repo-change": { "mode": "single-agent", "maxOutputTokens": 16000, "requiredChecks": ["non-empty", "no-placeholders"] }
  }
}
