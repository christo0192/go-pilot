# Go-pilot Mem0 deploy config — copy to deploy/.env and fill.
# deploy/.env is git-ignored (may hold a real key). This template is committed.

# --- Postgres (pgvector). Password is REQUIRED — compose won't start without it. ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=mem0devpass          # dev only; change for anything shared
POSTGRES_DB=postgres

# --- Auth: keep the local single-node store open (no JWT/api-key needed). ---
AUTH_DISABLED=true
MEM0_TELEMETRY=false

# --- Embedder + extraction LLM (REQUIRED for search). ---
# Mem0 needs a real EMBEDDER even though our client sends infer:false — pure-anthropic
# has no embeddings API, so supply an OpenAI key (text-embedding-3-small ≈ free), OR
# switch these to a local/OpenAI-compatible embedder. Extraction LLM (gpt-4.1-nano) is
# only exercised if infer:true; our client uses infer:false so it's rarely hit.
OPENAI_API_KEY=
MEM0_DEFAULT_EMBEDDER_MODEL=text-embedding-3-small
MEM0_DEFAULT_LLM_MODEL=gpt-4.1-nano-2025-04-14
