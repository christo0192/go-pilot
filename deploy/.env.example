# Go-pilot Mem0 deploy config — copy to deploy/.env and fill.
# deploy/.env is git-ignored (may hold a real key). This template is committed.

# --- Postgres (pgvector). Password is REQUIRED — compose won't start without it. ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=mem0devpass          # dev only; change for anything shared
POSTGRES_DB=postgres

# --- Auth: keep the local single-node store open (no JWT/api-key needed). ---
# DEV default (docker-compose.yml): AUTH_DISABLED=true.
# PROD (docker-compose.prod.yml): forces auth ON and REQUIRES the two secrets
# below — compose fails to start if either is unset/empty. Generate strong values,
# e.g.  openssl rand -hex 32
AUTH_DISABLED=true
MEM0_TELEMETRY=false
MEM0_JWT_SECRET=                    # prod-only: HS256 signing secret for Mem0 tokens
MEM0_ADMIN_API_KEY=                 # prod-only: admin X-API-Key the Mem0 client sends

# --- Embedder + extraction LLM (REQUIRED for search). ---
# Mem0 needs a real EMBEDDER even though our client sends infer:false — pure-anthropic
# has no embeddings API, so supply an OpenAI key (text-embedding-3-small ≈ free), OR
# switch these to a local/OpenAI-compatible embedder. Extraction LLM (gpt-4.1-nano) is
# only exercised if infer:true; our client uses infer:false so it's rarely hit.
OPENAI_API_KEY=
MEM0_DEFAULT_EMBEDDER_MODEL=text-embedding-3-small
MEM0_DEFAULT_LLM_MODEL=gpt-4.1-nano-2025-04-14

# --- Workhorse gateway KEY (PLUG-AND-PLAY: this is THE key you fill in). -----
# Auth key the orchestrator's Kimi/DeepSeek workers send to the gateway below.
# Hosted Ikey gateway: paste the key you were given. Self-hosting or using
# another OpenAI-compatible gateway: paste that gateway's key and change
# LITELLM_BASE_URL. Read at runtime by pi-delegate/gateway-call — never committed.
WORKHORSE_GATEWAY_KEY=

# --- Workhorse gateway base URL (what Pi workers talk to). ------------------
# DEFAULT (D34): the HOSTED "Ikey" gateway — a Go-pilot-run LiteLLM on Fly. One
# key, nothing to boot locally. Point workers at it and skip the local service:
LITELLM_BASE_URL=https://ikey-gateway.fly.dev
# OFFLINE / no-Ikey alternative: run the OPTIONAL local `litellm` service
# (docker compose --profile local-litellm up -d litellm) and set instead:
#   LITELLM_BASE_URL=http://127.0.0.1:4000

# --- OPTIONAL local LiteLLM gateway (the profiled `litellm` service). --------
# Only needed when NOT using Ikey (offline). Compose reads THIS file for variable
# substitution, so the litellm service picks up the keys below. ACTIVATE-BY-KEY:
# a model is usable only if its provider key is set; all blank = proxy still boots
# + serves health with 0 working models. OPENROUTER is universal (one key -> all
# models); the direct keys are optional. In PROD, LITELLM_MASTER_KEY is required
# (no dev default) if you start the local-litellm profile.
LITELLM_MASTER_KEY=sk-gopilot-dev   # Bearer token callers send; change if shared
OPENROUTER_API_KEY=                 # universal — one key -> all workhorse models
MOONSHOT_API_KEY=                   # Kimi   (direct, optional)
ZAI_API_KEY=                        # GLM    (direct, optional)
DEEPSEEK_API_KEY=                   # DeepSeek (direct, optional)
MINIMAX_API_KEY=                    # MiniMax  (direct, optional)
