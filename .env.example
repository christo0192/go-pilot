# Go-pilot environment — copy to .env and fill.
# FRONTIER plane (claude/codex) uses NATIVE subscription login — no keys here.

# ---- Model profile ----
# pure-anthropic | hybrid | open-first
GOPILOT_PROFILE=ikey-prod

# ---- WORKHORSE plane (only needed for hybrid / open-first) ----
# Open-model API keys, consumed by LiteLLM. ACTIVATE-BY-KEY: a model is usable
# ONLY if its provider key is set — a blank key just leaves that model inactive,
# so one config serves every user. Leave all blank for pure-anthropic.
# OPENROUTER is universal: this ONE key reaches every model (Kimi/GLM/DeepSeek/
# Qwen/MiniMax). The direct keys below are optional overrides for users with a
# dedicated vendor account (LiteLLM prefers the direct route when its key is set).
OPENROUTER_API_KEY=      # universal — one key -> all workhorse models
MOONSHOT_API_KEY=        # Kimi   (direct, optional)
ZAI_API_KEY=             # GLM    (direct, optional)
DEEPSEEK_API_KEY=        # DeepSeek (direct, optional)
MINIMAX_API_KEY=         # MiniMax  (direct, optional)

# ---- LiteLLM gateway (hybrid/open-first) ----
LITELLM_BASE_URL=http://localhost:4000
# Bearer token callers (Pi workers, scripts/verify-litellm.mjs) send to the proxy.
# Dev default matches deploy/docker-compose.yml; change for anything shared.
LITELLM_MASTER_KEY=sk-gopilot-dev

# ---- Mem0 (all profiles — persistent memory) ----
MEM0_BASE_URL=http://localhost:8888
# Mem0's internal extraction LLM. pure-anthropic: point at a cheap model you have access to.
MEM0_LLM_PROVIDER=
MEM0_LLM_KEY=

# ---- Herdr ----
HERDR_SOCKET=            # default resolved by herdr if blank
